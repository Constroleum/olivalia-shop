# ============================================================
# OLIVALIA — Environment Variables
# Másolja ezt a fájlt .env-re és töltse ki az értékeket
# Copy this file to .env and fill in the values
# ============================================================

# STRIPE
# Stripe Dashboard → Developers → API Keys
STRIPE_SECRET_KEY=sk_test_YOUR_STRIPE_SECRET_KEY
STRIPE_PUBLISHABLE_KEY=pk_test_YOUR_STRIPE_PUBLISHABLE_KEY

# Stripe Webhook Secret (Stripe Dashboard → Developers → Webhooks)
# Local testing: stripe listen --forward-to localhost:3000/webhook
STRIPE_WEBHOOK_SECRET=whsec_YOUR_WEBHOOK_SECRET

# GMAIL
# 1. constroleum@gmail.com fiókban engedélyezze a 2-faktoros hitelesítést
# 2. Google Fiók → Biztonság → Alkalmazásjelszók → Új jelszó létrehozása
GMAIL_USER=constroleum@gmail.com
GMAIL_APP_PASS=your_16_character_app_password

# ADMIN
# Saját jelszó az admin panelhez (admin.html)
ADMIN_KEY=olivalia_admin_2024

# SERVER
PORT=3000
FRONTEND_URL=http://localhost:3000
